<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- ── World-level plugins (no reference attribute) ─────────────── -->
  <gazebo>
    <plugin filename="gz-sim-diff-drive-system" name="gz::sim::systems::DiffDrive">
      <left_joint>left_wheel_joint</left_joint>
      <right_joint>right_wheel_joint</right_joint>
      <wheel_separation>0.4075</wheel_separation>
      <wheel_radius>0.11</wheel_radius>
      <max_linear_acceleration>0.5</max_linear_acceleration>
      <min_linear_acceleration>-0.5</min_linear_acceleration>
      <max_angular_acceleration>1.0</max_angular_acceleration>
      <min_angular_acceleration>-1.0</min_angular_acceleration>
      <max_linear_velocity>1.0</max_linear_velocity>
      <min_linear_velocity>-1.0</min_linear_velocity>
      <max_angular_velocity>2.0</max_angular_velocity>
      <min_angular_velocity>-2.0</min_angular_velocity>
      <topic>/cmd_vel</topic>
      <frame_id>odom</frame_id>
      <child_frame_id>base_link</child_frame_id>
      <odom_topic>/odom</odom_topic>
      <tf_topic>/tf</tf_topic>
      <odom_publish_frequency>50</odom_publish_frequency>
    </plugin>

    <plugin filename="gz-sim-joint-state-publisher-system"
      name="gz::sim::systems::JointStatePublisher">
      <topic>/joint_states</topic>
      <joint_name>left_wheel_joint</joint_name>
      <joint_name>right_wheel_joint</joint_name>
    </plugin>
  </gazebo>

  <!-- ── Link-level: base_link ─────────────────────────────────────── -->
  <gazebo reference="base_link">
    <material>Gazebo/White</material>
    <gravity>true</gravity>
    <surface>
      <friction>
        <ode>
          <mu>0.2</mu>
          <mu2>0.2</mu2>
        </ode>
      </friction>
      <contact>
        <ode>
          <kp>1e6</kp>
          <kd>100</kd>
        </ode>
      </contact>
    </surface>
  </gazebo>

  <!-- ── Link-level: left_wheel_link ────────────────────────────────────── -->
  <gazebo reference="left_wheel_link">
    <material>Gazebo/DarkGrey</material>
    <surface>
      <friction>
        <ode>
          <mu>1.5</mu>
          <mu2>0.5</mu2>
          <fdir1>1 0 0</fdir1>
          <slip1>0.001</slip1>
          <slip2>0.001</slip2>
        </ode>
      </friction>
      <contact>
        <ode>
          <kp>1e7</kp>
          <kd>1</kd>
          <min_depth>0.001</min_depth>
          <max_vel>0.5</max_vel>
        </ode>
      </contact>
    </surface>
  </gazebo>

  <!-- ── Link-level: right_wheel_link ───────────────────────────────────── -->
  <gazebo reference="right_wheel_link">
    <material>Gazebo/DarkGrey</material>
    <surface>
      <friction>
        <ode>
          <mu>1.5</mu>
          <mu2>0.5</mu2>
          <fdir1>1 0 0</fdir1>
          <slip1>0.001</slip1>
          <slip2>0.001</slip2>
        </ode>
      </friction>
      <contact>
        <ode>
          <kp>1e7</kp>
          <kd>1</kd>
          <min_depth>0.001</min_depth>
          <max_vel>0.5</max_vel>
        </ode>
      </contact>
    </surface>
  </gazebo>

  <!-- ── Link-level: caster wheels ───────────────────────────────────── -->
  <!-- We apply low friction to caster wheels to prevent them from catching and dragging in Gazebo -->
  <xacro:macro name="caster_gazebo" params="prefix">
    <gazebo reference="${prefix}_caster_link">
      <material>Gazebo/Grey</material>
    </gazebo>
    <gazebo reference="${prefix}_wheel_link">
      <material>Gazebo/DarkGrey</material>
      <surface>
        <friction>
          <ode>
            <mu>0.0</mu>
            <mu2>0.0</mu2>
          </ode>
        </friction>
        <contact>
          <ode>
            <kp>1e7</kp>
            <kd>1</kd>
            <min_depth>0.001</min_depth>
            <max_vel>0.5</max_vel>
          </ode>
        </contact>
      </surface>
    </gazebo>
  </xacro:macro>

  <xacro:caster_gazebo prefix="fl" />
  <xacro:caster_gazebo prefix="fr" />
  <xacro:caster_gazebo prefix="bl" />
  <xacro:caster_gazebo prefix="br" />

  <!-- ── Link-level: lidar_link — sensor ONLY here ─────────────────── -->
  <gazebo reference="lidar_link">
    <material>Gazebo/Black</material>
    <sensor name="lidar_sensor" type="gpu_lidar">
      <pose relative_to="lidar_link">0 0 0 0 0 0</pose>
      <topic>/scan</topic>
      <gz_frame_id>lidar_link</gz_frame_id>
      <update_rate>10</update_rate>
      <lidar>
        <scan>
          <horizontal>
            <samples>360</samples>
            <resolution>1</resolution>
            <min_angle>-3.14159</min_angle>
            <max_angle>3.14159</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.40</min>
          <max>10.0</max>
          <resolution>0.01</resolution>
        </range>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.001</stddev>
        </noise>
      </lidar>
      <visualize>true</visualize>
      <always_on>true</always_on>
    </sensor>
  </gazebo>

</robot>